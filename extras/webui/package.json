{
  "name": "affent-webui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Affent WebUI — agent runtime console (timeline, tools, artifacts, replay).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
