# affent .env example — copy to `.env` (gitignored) and fill in.
# Loaded at startup by affentctl + affentserve. Shell env wins over file.
# Lookup order: ./.env first, then ~/.config/affent/.env.

# --- affentctl ---
AFFENTCTL_BASE_URL=https://api.openai.com/v1
AFFENTCTL_API_KEY=sk-...
AFFENTCTL_MODEL=gpt-4o-mini
# AFFENTCTL_MCP_CONFIG=/abs/path/mcp.json
# AFFENTCTL_EXECUTOR=local            # or docker:<container_id>
# AFFENTCTL_CONFIG=/abs/path/config.json

# --- affentserve ---
# AFFENTSERVE_BASE_URL=https://api.openai.com/v1
# AFFENTSERVE_API_KEY=sk-...
# AFFENTSERVE_AUTH_TOKEN=bearer-for-the-server-itself
# AFFENTSERVE_WORKSPACE_ROOT=/var/affent/sessions

# --- extras/web (Tavily) ---
# TAVILY_API_KEY=tvly-...
